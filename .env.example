# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/founders_helper

# Redis
REDIS_URL=redis://localhost:6379/0

# Groq
GROQ_API_KEY=gsk_...

# Pinecone
PINECONE_API_KEY=...
PINECONE_INDEX=founders-helper

# Encryption — generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
MASTER_FERNET_KEY=...

# Ingestion mode: "simulate" (no credentials needed) or "real"
INGESTION_MODE=simulate
SIMULATOR_SPEED=normal

# Google OAuth (only needed for INGESTION_MODE=real)
GOOGLE_CLIENT_ID=...
GOOGLE_CLIENT_SECRET=...
GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/google/callback

# Slack (only needed for INGESTION_MODE=real)
SLACK_BOT_TOKEN=xoxb-...

# Clerk (frontend auth)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# Frontend
NEXT_PUBLIC_WS_URL=ws://localhost:8000
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_DEMO_USER_ID=demo-user-123
