FROM node:20-alpine

WORKDIR /app

COPY package.json package-lock.json* ./
RUN npm install

COPY . .

ARG NEXT_PUBLIC_WS_URL=ws://localhost:8001
ARG NEXT_PUBLIC_API_URL=http://localhost:8001
ARG NEXT_PUBLIC_INGESTION_MODE=simulate
ARG NEXT_PUBLIC_ALLOW_MANUAL_INGESTION=true
ARG NEXT_PUBLIC_DEMO_MODE=false
ARG BACKEND_INTERNAL_URL=http://backend:8000
ENV NEXT_PUBLIC_WS_URL=${NEXT_PUBLIC_WS_URL}
ENV NEXT_PUBLIC_API_URL=${NEXT_PUBLIC_API_URL}
ENV NEXT_PUBLIC_INGESTION_MODE=${NEXT_PUBLIC_INGESTION_MODE}
ENV NEXT_PUBLIC_ALLOW_MANUAL_INGESTION=${NEXT_PUBLIC_ALLOW_MANUAL_INGESTION}
ENV NEXT_PUBLIC_DEMO_MODE=${NEXT_PUBLIC_DEMO_MODE}
ENV BACKEND_INTERNAL_URL=${BACKEND_INTERNAL_URL}

RUN npm run build

EXPOSE 3000

ENV NODE_ENV=production
ENV HOSTNAME=0.0.0.0
ENV PORT=3000

CMD ["npm", "start"]
